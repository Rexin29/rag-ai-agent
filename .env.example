# Environment
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Database Configuration
# Metadata Database
DATABASE_URL=sqlite:///./data/rag_agent.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/rag_agent

# Vector Database
VECTOR_DB_TYPE=chroma  # Options: chroma, qdrant, faiss, milvus, pinecone, weaviate
VECTOR_DB_HOST=localhost
VECTOR_DB_PORT=8000
VECTOR_DB_PATH=./vector_store

# Qdrant Configuration (if using Qdrant)
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_URL=http://localhost:6333

# Pinecone Configuration (if using Pinecone)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_ENVIRONMENT=us-west1-gcp
PINECONE_INDEX=rag-index

# Embedding Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# LLM Configuration
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-opus-20240229
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-pro

# Chunking Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50
MIN_CHUNK_LENGTH=100

# Retrieval Configuration
TOP_K_RETRIEVAL=5
RETRIEVAL_THRESHOLD=0.5
ENABLE_RERANKING=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-12-v2

# Authentication
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Redis Cache
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600

# Storage Configuration
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./uploads

# AWS S3 Configuration (if using S3)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=rag-agent-bucket

# Azure Blob Storage (if using Azure)
AZURE_STORAGE_CONNECTION_STRING=your_azure_connection_string
AZURE_CONTAINER_NAME=rag-agent

# File Upload Configuration
MAX_FILE_SIZE=50
ALLOWED_FILE_TYPES=pdf,docx,doc,txt,csv,xlsx,xls,pptx,ppt,html,xml,json,md,png,jpg,jpeg,tiff,zip,eml,py,js,java,cpp

# OCR Configuration
ENABLE_OCR=true
OCR_LANGUAGE=eng

# Speech to Text Configuration
ENABLE_SPEECH_TO_TEXT=true
STT_PROVIDER=openai

# Logging
LOG_FILE=logs/rag_agent.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_ALLOW_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Feature Flags
ENABLE_STREAMING=true
ENABLE_AUTO_INDEXING=true
ENABLE_INCREMENTAL_UPDATES=true
ENABLE_DUPLICATE_DETECTION=true
